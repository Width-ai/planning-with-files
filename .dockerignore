# ---------------------------------------------------------------------------
# .dockerignore – exclude non-essential files from the Docker build context
# ---------------------------------------------------------------------------

# Version control
.git
.gitignore

# AI / editor agent directories
.claude
.cursor
.gemini
.codex
.opencode
.kilocode
.kiro
.openclaw
.factory
.agent
.codebuddy
.continue
.adal
.pi
.mastracode

# GitHub
.github

# Documentation
docs/
*.md
LICENSE

# PDF files
*.pdf

# Python artifacts
__pycache__
*.pyc
*.pyo
*.egg-info
dist/
build/
.eggs/

# Virtual environments
.venv
venv
env

# IDE / editor config
.vscode
.idea
*.swp
*.swo

# Environment files (secrets)
.env
.env.*

# Data directories (mounted as volumes instead)
matheson_deposition_pages/

# Miscellaneous
scripts/
examples/
templates/
commands/
skills/
*.json
